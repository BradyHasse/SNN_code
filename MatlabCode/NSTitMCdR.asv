        rs = performRotatedPCA(histo_all);
        AorP = "Actual";
    else
        rs = performRotatedPCA(histo_allP);
        AorP = "Predicted";
    end
    
    % Save the rotated PCA results
    save(sprintf('%s\\Data\\Monk%s_rPCA_%s.mat', CodeDir, Monk,AorP), 'rs');
    
    % Plot the rotated PCA components
