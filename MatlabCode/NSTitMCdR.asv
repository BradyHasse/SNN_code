%% Weights and firing rates of inputs triggering an output spike.
ClearCloseClc()
weights =   importdata(sprintf('%s\\Data\\Monk%s\\Monk%s_triggerFRW_%s.mat', CodeDir, Monk, Monk,MI{1,Mkind}, MI{2,Mkind}));

