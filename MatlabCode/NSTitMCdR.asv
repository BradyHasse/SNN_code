    plotRotatedPCATrajectories(rs, mean_ev, xax_labels*1000,colors, savePath,AorP);
    
    % Plot three pairs of PCA scores 2D plots
    plotRotatedPCATrajectories2d(rs,colors, savePath,AorP);
end
